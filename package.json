{
  "name": "robot-ruins",
  "version": "1.0.0",
  "description": "2.5D top-down robot shooter",
  "type": "module",
  "scripts": {
    "start": "node server/dev-server.mjs",
    "start:https": "npx --yes serve . -p 3000 -S",
    "start:network": "node server/dev-server.mjs",
    "dev": "node server/dev-server.mjs",
    "lan-server": "node server/lan-server.mjs",
    "pwa:icons": "powershell -ExecutionPolicy Bypass -File scripts/generate-pwa-icons.ps1",
    "inventory:template": "powershell -ExecutionPolicy Bypass -File scripts/generate-inventory-template.ps1",
    "font:convert": "python scripts/convert-ascii-font.py",
    "assets:organize": "powershell -ExecutionPolicy Bypass -File scripts/setup-asset-folders.ps1",
    "player:flatten": "powershell -ExecutionPolicy Bypass -File scripts/flatten-player-sprites.ps1",
    "weapons:setup": "python scripts/setup-weapon-sprites.py",
    "assets": "powershell -ExecutionPolicy Bypass -File scripts/generate-assets.ps1",
    "assets:new": "powershell -ExecutionPolicy Bypass -File scripts/generate-new-sprites.ps1",
    "map:template": "powershell -ExecutionPolicy Bypass -File scripts/generate-map-template.ps1"
  },
  "dependencies": {
    "ws": "^8.21.0"
  }
}
